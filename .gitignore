# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# =========================
# BACKEND (Express/Mongo)
# =========================

# node modules (server)
server/node_modules/

# environment variables (extra safety for backend)
server/.env

# logs
server/logs
*.log

# nodemon temp files
.nodemon

# OS / misc
Thumbs.db

# uploads (if you add file upload later)
server/uploads/

# =========================
# OPTIONAL (Monorepo style)
# =========================

# If you ever build backend
server/dist/